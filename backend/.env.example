# ════════════════════════════════════════════════════════════════
# QuantAI — 100% Free & Open-Source Configuration
# Every variable below is either optional or points to a free,
# self-hosted, or no-cost service. No credit card needed anywhere.
# ════════════════════════════════════════════════════════════════

# ── Database (open-source PostgreSQL/TimescaleDB, self-hosted) ───
DATABASE_URL=postgresql+asyncpg://quantai:quantai_pass@localhost:5432/quantai_db

# ── Redis (open-source, self-hosted) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI — Ollama (free, open-source, runs on your own machine) ─────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then:    ollama pull llama3.2
# No API key required — Ollama has no concept of billing.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── India Market Data (free, open-source libraries — no keys) ─────
# yfinance, jugaad-data, and nsepython all work with zero configuration.
# The two keys below are OPTIONAL and only extend macro data coverage —
# both are free to register, no payment ever required.
FRED_API_KEY=
DATA_GOV_IN_KEY=

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App Config ────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
