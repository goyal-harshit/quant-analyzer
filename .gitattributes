# Normalize line endings to LF in the repo; checkout native on Windows.
# Prevents the whole tree from showing as modified due to CRLF<->LF churn
# and keeps container/CI files correct on Linux.
* text=auto eol=lf

# Force LF for files that must be LF inside Linux containers/CI.
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
Dockerfile text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
